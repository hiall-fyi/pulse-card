{
  "name": "pulse-card",
  "version": "0.3.2",
  "private": true,
  "description": "Compact horizontal bar chart card for Home Assistant sensor data visualization",
  "author": "hiall-fyi",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/hiall-fyi/pulse-card"
  },
  "type": "module",
  "scripts": {
    "build": "esbuild src/pulse-card.js --bundle --outfile=dist/pulse-card.js --format=esm --minify --external:./editor.js && esbuild src/editor.js --bundle --outfile=dist/editor.js --format=esm --minify",
    "dev": "esbuild src/pulse-card.js --bundle --outfile=dist/pulse-card.js --format=esm --watch --external:./editor.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.0",
    "fast-check": "^3.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
